rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user owns the data
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Basic transaction validation - only check required fields exist
    function isValidTransaction() {
      let data = request.resource.data;
      return data.id is string &&
             data.type is string &&
             data.amount is number &&
             data.date is string &&
             data.note is string;
    }
    
    // User data rules
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow write: if false;
      
      // Transactions collection
      match /transactions/{transactionId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidTransaction();
        allow update: if isOwner(userId) && isValidTransaction();
        allow delete: if isOwner(userId);
      }
      
      // Budgets collection
      match /budgets/{budgetId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) &&
                       request.resource.data.keys().hasAll(['data']) &&
                       request.resource.data.data is map;
        allow delete: if isOwner(userId);
      }
      
      // Envelopes collection
      match /envelopes/{envelopeId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) &&
                       request.resource.data.keys().hasAll(['data']) &&
                       request.resource.data.data is list;
        allow delete: if isOwner(userId);
      }
      
      // Payment methods collection
      match /paymentMethods/{methodId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) &&
                       request.resource.data.keys().hasAll(['data']) &&
                       request.resource.data.data is list;
        allow delete: if isOwner(userId);
      }

      // Preferences collection
      match /preferences/{prefId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) &&
                       request.resource.data.keys().hasAll(['data']) &&
                       request.resource.data.data is map;
        allow delete: if isOwner(userId);
      }
    }
    
    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
